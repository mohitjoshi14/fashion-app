# Use the key that matches PROVIDER in the notebook.
OPENAI_API_KEY=

# Anthropic: use ONE of these (OAuth bearer token OR API key — not both).
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_API_KEY=

OPENROUTER_API_KEY=

# Optional (OpenRouter attribution)
# OPENROUTER_HTTP_REFERER=https://github.com/your/repo

# Gmail Myntra extractor
# Path to the Google OAuth desktop client JSON downloaded from Google Cloud Console.
GMAIL_OAUTH_CLIENT_PATH=./config/gmail-oauth-client.json

# Where the OAuth refresh token is cached after first login.
GMAIL_OAUTH_TOKEN_PATH=./config/gmail-token.json

# Optional time filter and query override for Gmail search.
# Leave GMAIL_TIME_FILTER unset to search without a date limit.
# Examples:
# GMAIL_TIME_FILTER=newer_than:365d
# GMAIL_TIME_FILTER=after:2025/01/01
# GMAIL_TIME_FILTER=older_than:30d
# GMAIL_QUERY=from:myntra.com ("order confirmed" OR shipped) -in:chats
# Cap the number of Gmail messages fetched before parsing.
# Recommended while iterating:
# GMAIL_MAX_MESSAGES=100
# Set to true to include per-message match/rejection reasons in the output JSON.
# GMAIL_DEBUG_MATCHES=true
GMAIL_TIME_FILTER=

# Optional export path for the extracted Myntra purchases JSON.
# GMAIL_ORDERS_OUTPUT_PATH=./outputs/ecommerce-gmail-orders.json
